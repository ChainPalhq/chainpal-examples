# Copy to `.env` and fill in your own values. Never commit `.env`.
#
# Environment must match the prefix on your keys:
#   cp_(pk|sk)_test_…  →  test
#   cp_(pk|sk)_live_…  →  live
VITE_API_ENV=test

# Public key (cp_pk_test_… or cp_pk_live_…). Used for POST /payments
# and POST /payments/quote. Safe to ship to the browser.
VITE_PUBLIC_KEY=

# Secret key (cp_sk_test_… or cp_sk_live_…). Used for verify + list.
# In a real integration this belongs on your server. The demo accepts
# one only so all endpoints can be exercised from one page.
VITE_SECRET_KEY=

# API base URL. Point to your local API (default below) or to ChainPal:
#   https://api.chainpal.org/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1
